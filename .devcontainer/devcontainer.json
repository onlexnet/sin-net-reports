// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
	"name": "onlexnet-sinnet",
	// Alternative base setup guidance: https://containers.dev/guide/dockerfile
    "image": "mcr.microsoft.com/vscode/devcontainers/base:ubuntu-22.04",
	"features": {
		"ghcr.io/devcontainers/features/github-cli:1": {
			// GitHub CLI
		},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {
		},
		"ghcr.io/devcontainers/features/java:1": {
			"installMaven": true,
			"installGradle": false,
			"installAnt": false,
			"version": "25.0",
			"jdkDistro": "librca",
			"mavenVersion": "3.9.9"
		},
		"ghcr.io/dapr/cli/dapr-cli:0": {
		},
		"ghcr.io/devcontainers/features/node:2.1.0": {
			"version": "22.12.0"
		},
		"ghcr.io/devcontainers/features/python:1": {
			"version": "3.13"
		},
		"ghcr.io/devcontainers/features/azure-cli:": {
			"installUsingPython": true,
			"version": "latest"
		},
        "ghcr.io/devcontainers/features/terraform:1": {
            "version": "1.15.2"
        },
        "ghcr.io/dhoeric/features/terraform-docs:1": {
            "version": "latest"
        },
		// required for MPC from Microsoft
	    "ghcr.io/devcontainers/features/dotnet:2": {
			"version": "10.0.103"
		},
		// required by azure functions, e.g. report1
	   	"ghcr.io/jlaundry/devcontainer-features/azure-functions-core-tools:1": {

		}
	},
	"customizations": {
        "vscode": {
            "extensions": [
				"hashicorp.terraform",
				"editorconfig.editorconfig",
				"jebbs.plantuml",
				"vscjava.vscode-java-pack",
				"vmware.vscode-boot-dev-pack",
				"github.vscode-github-actions",
				"ms-python.python",
				"Orta.vscode-jest",
				"matangover.mypy",
				"ms-vscode.vscode-chat-customizations-evaluations"
			],
            "settings": {
                "terraform.languageServer": {
                    "enabled": true,
                    "args": [ "serve" ]
                }
            }
        }
    },

	// as the container is run in another container on CICD, we have to manually reuse host env variables reuqired for CI builds
	"containerEnv": {
		"GITHUB_RUN_ID": "${localEnv:GITHUB_RUN_ID}"
	},
    // Required by terraform extension
    "remoteEnv": {
        "TF_LOG": "'info",
        "TF_LOG_PATH": "'./terraform.log"
	},
	"mounts": [
		"source=sinnet-terraform-config,target=/home/vscode/.terraform.d,type=volume"
	],
	"postCreateCommand": "sudo mkdir -p /home/vscode/.terraform.d && sudo chown -R vscode:vscode /home/vscode/.terraform.d && chmod 700 /home/vscode/.terraform.d && if [ -f /home/vscode/.terraform.d/credentials.tfrc.json ]; then chmod 600 /home/vscode/.terraform.d/credentials.tfrc.json; fi",
	"postStartCommand": "sudo mkdir -p /home/vscode/.terraform.d && sudo chown -R vscode:vscode /home/vscode/.terraform.d && chmod 700 /home/vscode/.terraform.d && if [ -f /home/vscode/.terraform.d/credentials.tfrc.json ]; then chmod 600 /home/vscode/.terraform.d/credentials.tfrc.json; fi"
	
	// https://stackoverflow.com/a/75644266
	// "mounts": [
	// 	"type=bind,source=/home/${localEnv:USER}/.ssh,target=/home/node/.ssh"
	// ]

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "uname -a",

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
